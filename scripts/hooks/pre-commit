#!/bin/sh
# Pre-commit hook to regenerate TypeScript types from Rust
# when Rust source files are modified.
#
# Activate with: git config core.hooksPath scripts/hooks
# (See README "Setup" / CLAUDE.md "Initial Setup".)

# Check if any Rust files are being committed
if git diff --cached --name-only | grep -q '\.rs$'; then
    echo "🔄 Rust files modified, regenerating TypeScript types..."

    # Capture cargo's actual exit status — piping through grep would mask it
    # (in /bin/sh, $? after a pipeline reflects only the last command).
    # Run in a subshell so cwd is restored afterward; otherwise the git add
    # below resolves relative to src-tauri/ and silently stages nothing.
    cargo_out=$(mktemp)
    if ( cd src-tauri && cargo test --lib export_bindings --quiet ) >"$cargo_out" 2>&1; then
        grep -v "running 0 tests" "$cargo_out" | grep -v "test result: ok"
        rm -f "$cargo_out"
        echo "✅ TypeScript types regenerated"

        # Stage any modified TypeScript type files
        git add src/lib/types/*.ts 2>/dev/null

        # Check if any types were actually updated
        if git diff --cached --name-only | grep -q 'src/lib/types/.*\.ts$'; then
            echo "📝 Updated types staged for commit"
        fi
    else
        cat "$cargo_out" >&2
        rm -f "$cargo_out"
        echo "❌ Failed to regenerate types" >&2
        exit 1
    fi
fi

exit 0
