/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.per-ankh.app; img-src 'self' data:; font-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'

# Atlas + sprite assets are content-hashed (filename embeds an 8-char sha256
# prefix), so they're safe to cache forever. The same files live at
# per-ankh.app via symlink from this site's static/atlases and static/sprites
# directories. Mirrors the rules in the root _headers of the per-ankh repo.
/atlases/*
  Cache-Control: public, max-age=31536000, immutable

/sprites/*
  Cache-Control: public, max-age=31536000, immutable
