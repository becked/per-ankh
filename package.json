{
	"name": "per-ankh",
	"version": "0.3.0",
	"description": "Web analytics for Old World save files",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint src",
		"lint:fix": "eslint src --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"bake:terrain-3d": "tsx scripts/bake-terrain-3d.ts",
		"bake:improvements": "tsx scripts/bake-improvements.ts",
		"bake:resources": "tsx scripts/bake-resources.ts",
		"bake:crests": "tsx scripts/bake-crests.ts",
		"bake:sprites": "tsx scripts/bake-sprites.ts",
		"bake:all": "npm run bake:terrain-3d && npm run bake:improvements && npm run bake:resources && npm run bake:sprites && npm run bake:crests"
	},
	"license": "MIT",
	"dependencies": {
		"@deck.gl/core": "^9.2.3",
		"@deck.gl/layers": "^9.2.3",
		"bits-ui": "^2.14.2",
		"echarts": "^6.0.0",
		"fast-xml-parser": "^5.7.2",
		"fflate": "^0.8.2"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.9.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@typescript-eslint/eslint-plugin": "^8.54.0",
		"@typescript-eslint/parser": "^8.54.0",
		"autoprefixer": "^10.4.21",
		"baseline-browser-mapping": "^2.9.19",
		"dotenv": "^17.4.2",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"postcss": "^8.5.6",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"sharp": "^0.34.5",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^3.4.18",
		"tsx": "^4.21.0",
		"typescript": "~5.6.2",
		"vite": "^6.0.3"
	}
}
