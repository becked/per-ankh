# Per-Ankh build-time configuration. Copy this file to `.env` and fill in
# absolute paths for your local checkouts. The `.env` file itself is
# gitignored — only this template is committed.

# Path to your pinacotheca checkout (https://github.com/becked/pinacotheca).
# Required by scripts/bake-*.ts to read extracted sprites and pyproject.toml.
PINACOTHECA_DIR=

# Path to the Old World reference root containing an `XML/` subdir — typically
# a checkout of (or symlink into) the game install's reference data. Required
# by scripts/bake-improvements.ts to read improvement.xml + nation.xml + mods.
OLD_WORLD_REFERENCE_DIR=
