{
	"name": "per-ankh-share-api",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy",
		"migrate:local": "wrangler d1 migrations apply per-ankh-share-index --local",
		"migrate:remote": "wrangler d1 migrations apply per-ankh-share-index --remote",
		"migrate:staging": "wrangler d1 migrations apply per-ankh-share-index-staging --env staging --remote",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"fflate": "^0.8.3",
		"nanoid": "^5.0.0",
		"valibot": "^1.3.1"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.16.5",
		"@cloudflare/workers-types": "^4.20241205.0",
		"typescript": "^5.6.0",
		"vitest": "^4.1.6",
		"wrangler": "^4.0.0"
	}
}
